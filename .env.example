# Groww Ops Intelligence Suite environment inventory
# Copy to .env.local for local Next.js development. Keep real secrets out of git.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
# Used to encrypt secure-details submissions outside AI chat transcripts.
SECURE_DETAILS_ENCRYPTION_KEY=

# Supabase (Postgres app DB)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
# When SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are set, chat history is persisted to
# Supabase Postgres (preferred). Without them, chat history falls back to local SQLite at
# .data/chat-history.sqlite (See ADR-019). The UI works in both cases.

# Gemini / Google AI
GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_GENERATION_FALLBACK_MODEL=gemini-2.5-pro
GEMINI_CLASSIFICATION_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Optional Groq — classification/safety primary, generation last-resort fallback
GROQ_API_KEY=
GROQ_CLASSIFICATION_MODEL=
GROQ_GENERATION_FALLBACK_MODEL=llama-3.3-70b-versatile

# Deepgram voice STT + TTS (shared $200 signup credits)
DEEPGRAM_API_KEY=

# Scheduler LLM fallback (ADR-025) — set to "true" to enable Gemini structured output
# fallback for intent classification and day resolution when regex returns unclear.
# SCHEDULER_LLM_FALLBACK=true
# SCHEDULER_LLM_MODEL=gemini-2.5-flash-lite

# ChromaDB local/sidecar vector store
CHROMA_URL=http://localhost:8001
CHROMA_COLLECTION=smart-sync-kb
RAG_SOURCE_MANIFEST_PATH=config/source_urls.json
RAG_FEE_EXPLAINER_PATH=config/static_fee_explainer.md
RAG_FORCE_REINGEST=false
# Optional: pacing for Gemini embedding quota during ingestion
# RAG_EMBED_STAGGER_MS=120
# RAG_EMBED_MAX_ATTEMPTS=6
# Optional Phase 3 scraper tuning (403 mitigation)
# PLAYWRIGHT_CHROME_CHANNEL=chrome
# RAG_SCRAPER_USER_AGENT=Mozilla/5.0 ...

# FastMCP sidecar — TS app talks to Python over MCP SSE (see mcp/README.md).
MCP_SERVER_URL=http://localhost:8000/sse
# FASTMCP_HOST=127.0.0.1
# FASTMCP_PORT=8000

# Google OAuth — paths to client JSON + user token JSON (credentials/ is gitignored)
GOOGLE_CREDENTIALS_PATH=./credentials/credentials.json
GOOGLE_TOKEN_PATH=./credentials/token.json
# Calendar: often "primary" or your calendar email
GOOGLE_ADVISOR_CALENDAR_ID=
# Sheet id from URL .../spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=
# Worksheet tab name (must exist in that spreadsheet)
GOOGLE_SHEET_TAB=Bookings
# Same Google account as OAuth; used for Gmail drafts
GOOGLE_ADVISOR_EMAIL=
# OAuth loopback (default port 8765). If your Cloud client type is **Web application**,
# add redirect URIs: http://localhost:8765/ and http://127.0.0.1:8765/
# Prefer **Desktop app** client → you do not configure redirect URIs.
# GOOGLE_OAUTH_LOCAL_PORT=8765

# Google Play review ingestion
GOOGLE_PLAY_PACKAGE_NAME=com.nextbillion.groww
GOOGLE_PLAY_REVIEW_LIMIT=500
REVIEW_INGESTION_WINDOW_WEEKS=12

# GitHub Actions secrets / variables to configure in repository settings
GH_SUPABASE_URL=
GH_SUPABASE_SERVICE_ROLE_KEY=
GH_GEMINI_API_KEY=
GH_CHROMA_URL=
GH_GOOGLE_CREDENTIALS_JSON=
GH_GOOGLE_TOKEN_JSON=
GH_GOOGLE_ADVISOR_CALENDAR_ID=
GH_GOOGLE_SHEET_ID=
GH_GOOGLE_ADVISOR_EMAIL=
GH_DEEPGRAM_API_KEY=
